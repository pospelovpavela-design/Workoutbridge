# ── Database ──────────────────────────────────────────────
# Neon (https://neon.tech) or any PostgreSQL URL
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# ── Strava ────────────────────────────────────────────────
# Create app at https://www.strava.com/settings/api
# Callback domain: localhost (dev) / yourdomain.com (prod)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Any random string — used to verify Strava webhook pings
STRAVA_WEBHOOK_VERIFY_TOKEN=random-secret-string

# ── Garmin Connect ────────────────────────────────────────
# Your Garmin Connect account credentials (used to upload activities)
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# ── Redis ─────────────────────────────────────────────────
# Upstash Redis (https://upstash.com) or local redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Cron ──────────────────────────────────────────────────
# Vercel generates this automatically; set manually for local testing
CRON_SECRET=generate-with-openssl-rand-hex-32

# ── Email (optional) ──────────────────────────────────────
# Resend (https://resend.com) — leave blank to disable email notifications
RESEND_API_KEY=
EMAIL_FROM=Workoutbridge <noreply@yourdomain.com>
